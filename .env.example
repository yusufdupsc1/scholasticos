# .env.example
# ─────────────────────────────────────────────────────────
# BD-GPS — Environment Variables
# Copy this to .env.local for local development
# ─────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────
# Runtime connection (for app queries). For Supabase use pooled URL (usually port 6543).
DATABASE_URL="postgresql://bd-gps:password@localhost:5432/bd-gps"
# Migration connection (for Prisma migrate). For Supabase use direct/session URL (usually port 5432).
DIRECT_URL="postgresql://bd-gps:password@localhost:5432/bd-gps"

# ── Auth.js v5 ───────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-minimum-32-characters-here"
AUTH_URL="http://localhost:3000"

# Demo / owner login controls
# Keep demo login disabled in production-like environments.
ALLOW_DEMO_LOGIN="false"

# Owner super-admin credentials (must be provided/approved by developer team)
OWNER_SUPER_ADMIN_USERNAME="Yusuf_Ali"
OWNER_SUPER_ADMIN_EMAIL="yusuf_ali"
OWNER_SUPER_ADMIN_PASSWORD="replace-with-approved-owner-password"
OWNER_SUPER_ADMIN_NAME="Yusuf_Ali"

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── App ──────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Optional Supabase publishable key (frontend-only)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
GOVT_PRIMARY_MODE="true"
NEXT_PUBLIC_GOVT_PRIMARY_MODE="true"
NODE_ENV="development"
CRON_SECRET="replace-with-strong-random-secret"
ENABLE_AI_ASSIST="false"
# Enable Bangladeshi demo placeholder certificates/progress in seed.ts
ENABLE_DEMO_PLACEHOLDERS="false"
# Keep false when using CSV import so seed doesn't recreate synthetic students.
SEED_DEMO_STUDENTS="false"
AUTO_DOCS_ENABLED="true"
REALTIME_PROVIDER="sse"

# Demo CSV import controls (scripts/import-bd-demo-students.mjs)
DEMO_INSTITUTION_SLUG="bd-gps"
BD_DEMO_CSV_PATH="/absolute/path/to/BD_School_60_Students_Demo_Data_2026.csv"

# ── Push Notifications (Web Push / VAPID) ───
PUSH_VAPID_PUBLIC_KEY=""
PUSH_VAPID_PRIVATE_KEY=""
PUSH_VAPID_SUBJECT="mailto:ops@bd-gps.com"

# ── Email — Resend ───────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="noreply@bd-gps.app"

# ── File Uploads — UploadThing ───────────────
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# ── Payments — Stripe ────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── Payments — SSLCommerz (Bangladesh) ──────
SSLCOMMERZ_STORE_ID=""
SSLCOMMERZ_STORE_PASSWORD=""
SSLCOMMERZ_SANDBOX="true"

# ── OTP Login — Twilio Verify ────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_VERIFY_SERVICE_SID=""
